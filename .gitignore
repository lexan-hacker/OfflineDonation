```gitignore
# Dependencies
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Build artifacts
dist/
build/
*.o
*.obj

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Compiled and binary
*.exe
*.dll
*.so
*.a
*.out

# System files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
target/
*.egg-info/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```